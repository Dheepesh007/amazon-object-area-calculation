        "# SESSION 11 – AMAZON (Object Area)\n",
        "\n",
        "# Define width and height in pixels\n",
        "width = 60\n",
        "height = 30\n",
        "\n",
        "# Calculate area\n",
        "area = width * height\n",
        "\n",
        "# Display results\n",
        "print(\"Width:\", width, \"px\")\n",
        "print(\"Height:\", height, \"px\")\n",
        "print(\"Area:\", area, \"px²\")"
      ]
    }
  ]
